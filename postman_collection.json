    { "key": "store_phone", "value": "+923111111111", "type": "string" },
    { "key": "rider_phone", "value": "+923331234567", "type": "string" },
    { "key": "restaurant_id", "value": "cmn6iasf50006b8d46b5m1xbm", "type": "string" },
    { "key": "grocery_id",    "value": "cmn6iasf70007b8d4tzlc52ge", "type": "string" },
