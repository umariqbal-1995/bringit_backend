            {
              "name": "Send OTP",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/auth/send-otp",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{user_phone}}\"\n}" }
              }
            },
            {
              "name": "Verify OTP → get token",
              "event": [{
                "listen": "test",
                "script": { "exec": ["var r = pm.response.json();", "if(r.success) pm.collectionVariables.set('user_token', r.data.token);"], "type": "text/javascript" }
              }],
              "request": {
                "method": "POST",
                "url": "{{base_url}}/auth/verify-otp",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{user_phone}}\",\n  \"otp\": \"123456\"\n}" }
              }
