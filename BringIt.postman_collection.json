    {
      "name": "Rider App",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login (Send OTP)",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/rider/auth/login",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"+1234567890\"\n}"
                }
              }
            },
            {
              "name": "Refresh Token (Verify OTP)",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/rider/auth/refresh-token",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"+1234567890\",\n  \"otp\": \"123456\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "Get Me",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/rider/me",
                "header": [{ "key": "Authorization", "value": "Bearer {{riderToken}}" }]
              }
            },
            {
              "name": "Update Me",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/rider/me",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{riderToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Rider Name\"\n}"
                }
              }
            },
            {
              "name": "Update Availability",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/rider/availability",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{riderToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"isAvailable\": true\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Location",
          "item": [
            {
              "name": "Update Location",
              "request": {
                "method": "POST",
