{
  "info": {
    "name": "BringIt API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:3000/api/v1" },
    { "key": "userToken",  "value": "" },
    { "key": "storeToken", "value": "" },
    { "key": "riderToken", "value": "" },
    { "key": "addressId",  "value": "" },
    { "key": "storeId",    "value": "" },
    { "key": "itemId",     "value": "" },
    { "key": "orderId",    "value": "" },
    { "key": "notifId",    "value": "" },
    { "key": "productId",  "value": "" },
    { "key": "menuItemId", "value": "" },
    { "key": "riderId",    "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "User App",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Send OTP",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/send-otp",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"+1234567890\"\n}"
                }
              }
            },
            {
              "name": "Verify OTP",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/verify-otp",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"+1234567890\",\n  \"otp\": \"123456\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "Get Me",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/me",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Update Me",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/me",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"John Doe\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Addresses",
          "item": [
            {
              "name": "Get Addresses",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/addresses",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Create Address",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/addresses",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"label\": \"Home\",\n  \"address\": \"123 Main St\",\n  \"lat\": 40.7128,\n  \"lng\": -74.0060\n}"
                }
              }
            },
            {
              "name": "Update Address",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/addresses/{{addressId}}",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"label\": \"Work\",\n  \"address\": \"456 Office Ave\",\n  \"lat\": 40.7128,\n  \"lng\": -74.0060\n}"
                }
              }
            },
            {
              "name": "Delete Address",
              "request": {
                "method": "DELETE",
                "url": "{{baseUrl}}/addresses/{{addressId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            }
          ]
        },
        {
          "name": "Stores & Restaurants",
          "item": [
            {
              "name": "List Stores",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/stores?page=1&limit=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["stores"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "10" }
                  ]
                }
              }
            },
            {
              "name": "List Restaurants",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/restaurants?page=1&limit=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["restaurants"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "10" }
                  ]
                }
              }
            },
            {
              "name": "Get Store Products",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/stores/{{storeId}}/products"
              }
            },
            {
              "name": "Get Restaurant Menu",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/restaurants/{{storeId}}/menu"
              }
            }
          ]
        },
        {
          "name": "Cart",
          "item": [
            {
              "name": "Get Cart",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/cart/{{storeId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Add Cart Item",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/cart/{{storeId}}/items",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
                }
              }
            },
            {
              "name": "Update Cart Item",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/cart/{{storeId}}/items/{{itemId}}",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"quantity\": 3\n}"
                }
              }
            },
            {
              "name": "Delete Cart Item",
              "request": {
                "method": "DELETE",
                "url": "{{baseUrl}}/cart/{{storeId}}/items/{{itemId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Clear Cart",
              "request": {
                "method": "DELETE",
                "url": "{{baseUrl}}/cart/{{storeId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            }
          ]
        },
        {
          "name": "Orders",
          "item": [
            {
              "name": "Place Order",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/orders",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"storeId\": \"{{storeId}}\",\n  \"addressId\": \"{{addressId}}\"\n}"
                }
              }
            },
            {
              "name": "Get My Orders",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/orders",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Get My Order",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/orders/{{orderId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Cancel Order",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/orders/{{orderId}}/cancel",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"reason\": \"Changed my mind\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Notifications",
          "item": [
            {
              "name": "Get Notifications",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/notifications",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Mark Notification Read",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/notifications/{{notifId}}/read",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Mark All Notifications Read",
              "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/notifications/read-all",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            }
          ]
        },
        {
          "name": "Favorites",
          "item": [
            {
              "name": "Get Favorites",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/favorites",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Add Favorite",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/favorites/{{storeId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            },
            {
              "name": "Remove Favorite",
              "request": {
                "method": "DELETE",
                "url": "{{baseUrl}}/favorites/{{storeId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Store App",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Send OTP",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/store/auth/send-otp",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"+1234567890\"\n}"
                }
              }
            },
            {
              "name": "Verify OTP",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/store/auth/verify-otp",
