              }
            }
          ]
        },
        {
          "name": "Orders",
          "item": [
            {
              "name": "Get Store Orders",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/store/orders",
                "header": [{ "key": "Authorization", "value": "Bearer {{storeToken}}" }]
              }
            },
            {
              "name": "Get Store Order",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/store/orders/{{orderId}}",
                "header": [{ "key": "Authorization", "value": "Bearer {{storeToken}}" }]
              }
            },
            {
              "name": "Accept Order",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/store/orders/{{orderId}}/accept",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{storeToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
