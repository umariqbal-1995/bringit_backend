# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/bringit_db"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
JWT_USER_SECRET="replace_with_strong_random_secret"
JWT_STORE_SECRET="replace_with_strong_random_secret"
JWT_RIDER_SECRET="replace_with_strong_random_secret"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# ─── Redis Cache TTL (seconds) ────────────────────────────────────────────────
CACHE_TTL_STORES_LIST=300
CACHE_TTL_STORE=120
CACHE_TTL_STORE_PRODUCTS=120
CACHE_TTL_STORE_MENU=120
CACHE_TTL_RIDER_LOCATION=60

# ─── Rider Assignment ─────────────────────────────────────────────────────────
RIDER_ASSIGNMENT_RETRY_INTERVAL_MS=30000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Firebase Admin SDK (push notifications) ─────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the downloaded JSON as a single-line string value below:
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"bringit-5fc69","private_key_id":"REPLACE","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-REPLACE@bringit-5fc69.iam.gserviceaccount.com","client_id":"REPLACE","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"REPLACE"}'
# Alternative: point to the downloaded JSON file path
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/serviceAccountKey.json"
